class Solution:
    def findMaxAverage(self, nums: List[int], k: int) -> float:
        
        max_avg = float("-inf")

        if len(nums)<k:
            return ((sum[nums])/k)

        for i in range(len(nums)-k+1):
            sum = 0

            for j in range(k):
                sum += nums[j+i]

            avg = sum/k

            if avg > max_avg:
                max_avg = avg

        return max_avg             